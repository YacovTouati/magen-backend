generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum UserRole {
  ADMIN
  VOLUNTEER
}

model User {
  id               Int               @id @default(autoincrement())
  email            String            @unique
  password         String
  name             String
  role             UserRole          @default(VOLUNTEER)
  reports          CallReport[]
  assignedIntakes  Intake[]
  shiftAssignments ShiftAssignment[]
  createdAt        DateTime          @default(now())
}

model ShiftAssignment {
  id          Int      @id @default(autoincrement())
  date        DateTime @unique

  volunteerId Int
  volunteer   User     @relation(fields: [volunteerId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([volunteerId])
}

enum IntakeUrgency {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum IntakeStatus {
  NEW
  NO_ANSWER
  ACTIVE
  CLOSED
  LONG_TERM
}

model Intake {
  id                   Int           @id @default(autoincrement())
  callerName           String
  phone                String
  contactedOtherCenter String
  caseDescription      String
  urgency              IntakeUrgency
  status               IntakeStatus  @default(NEW)

  assignedToId         Int?
  assignedTo           User?         @relation(fields: [assignedToId], references: [id])

  callReportId         Int?          @unique
  callReport           CallReport?   @relation(fields: [callReportId], references: [id])

  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@index([assignedToId])
  @@index([status])
  @@index([createdAt])
}

model CallReport {
  id                         Int       @id @default(autoincrement())
  callDuration               Int
  callerType                 String
  callPurpose                String
  summaryNotes               String
  callerName                 String
  phone                      String
  email                      String?
  region                     String
  gender                     String
  sector                     String
  contactedOtherCenterBefore Boolean
  reportingDuty              Boolean?
  createdAt                  DateTime  @default(now())

  createdById                Int?
  createdBy                  User?     @relation(fields: [createdById], references: [id])

  intake                     Intake?

  @@index([createdById])
  @@index([createdAt])
}
