generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

// Cut over to Postgres (from the SQLite used during early local development).
// Local dev now requires a real Postgres instance — see .env for connection
// string parameters (sslmode, connection_limit, pool_timeout, pgbouncer).
// Note: Prisma 7 no longer allows `url` here — the connection string is supplied
// via prisma.config.ts (for the CLI) and via the adapter in src/db/prisma.ts
// (for the runtime client).
datasource db {
  provider = "postgresql"
}

// SUPER_ADMIN is the full-access superset that replaces the old flat ADMIN
// role; INTAKE_ADMIN and SCHEDULER_ADMIN are scoped admin types that only
// gate their own domain (see checkRole(...) call sites in routes/).
enum UserRole {
  SUPER_ADMIN
  INTAKE_ADMIN
  SCHEDULER_ADMIN
  VOLUNTEER
}

model User {
  id       Int      @id @default(autoincrement())
  email    String   @unique
  password String
  name     String
  phone    String?
  role     UserRole @default(VOLUNTEER)

  // Single active reset token at a time — a fresh forgot-password request
  // simply overwrites these, implicitly invalidating whatever was pending.
  // Stores a SHA-256 hash, never the raw token (see src/utils/tokens.ts) —
  // a DB dump alone must never be enough to reset every account.
  passwordResetTokenHash String?
  passwordResetExpiresAt DateTime?

  reports          CallReport[]
  shiftAssignments ShiftAssignment[]
  shifts           Shift[]
  sentInvites      InvitedUser[]     @relation("InvitedBy")
  createdAt        DateTime          @default(now())
}

// The invite-only whitelist: an admin creates one of these (email + role,
// no password — the invitee sets their own at registration), and only a
// matching, unexpired, unused row lets POST /auth/register succeed for
// that email.
model InvitedUser {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  role      UserRole
  // SHA-256 hash of the raw token that goes out in the invite link/email —
  // same rationale as User.passwordResetTokenHash.
  tokenHash String    @unique
  expiresAt DateTime
  // null = still pending; set once POST /auth/register consumes it. Kept
  // (not deleted) as an audit trail of who accepted an invite and when.
  usedAt DateTime?

  invitedById Int?
  invitedBy   User? @relation("InvitedBy", fields: [invitedById], references: [id])

  createdAt DateTime @default(now())

  @@index([email])
  @@index([expiresAt])
}

model ShiftAssignment {
  id   Int      @id @default(autoincrement())
  date DateTime @unique

  volunteerId Int
  volunteer   User @relation(fields: [volunteerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([volunteerId])
}

// --- Volunteer self-service shift booking (coexists with ShiftAssignment,
// which stays as-is for admin pre-assignment / blocking out days) ---

enum ScheduleStatus {
  DRAFT
  OPEN
}

enum ShiftType {
  MORNING
  EVENING
}

enum ShiftStatus {
  OPEN
  LOCKED
}

model Schedule {
  id     Int            @id @default(autoincrement())
  // Natural 1-12, not JS Date's 0-indexed convention — this is a DB value future
  // integrations/reports will read directly; the API layer translates at the
  // boundary so the existing 0-indexed frontend calendar doesn't need to change.
  month  Int
  year   Int
  status ScheduleStatus @default(DRAFT)
  shifts Shift[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([month, year])
}

model Shift {
  id     Int         @id @default(autoincrement())
  date   DateTime
  type   ShiftType
  status ShiftStatus @default(OPEN)

  scheduleId Int
  schedule   Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  // SetNull (not Cascade, unlike ShiftAssignment): a locked shift is a historical
  // record of who worked it. Deleting the volunteer should clear the assignment,
  // not erase that the shift happened.
  volunteerId Int?
  volunteer   User? @relation(fields: [volunteerId], references: [id], onDelete: SetNull)

  // Set when a claim succeeds; also cleared/reset by an admin release. Cheap
  // audit trail, useful the moment anyone asks "when was this actually claimed."
  lockedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date, type])
  @@index([scheduleId])
  @@index([status])
  @@index([volunteerId])
}

enum IntakeUrgency {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum IntakeStatus {
  NEW
  NO_ANSWER
  ACTIVE
  CLOSED
  LONG_TERM
}

model Intake {
  id                   Int           @id @default(autoincrement())
  callerName           String
  phone                String
  contactedOtherCenter String
  caseDescription      String
  urgency              IntakeUrgency
  status               IntakeStatus  @default(NEW)

  callReportId Int?        @unique
  callReport   CallReport? @relation(fields: [callReportId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Data-retention deadline, not a business date — set by the DB itself so
  // every creation path (manual admin creation, CallReport auto-linking, any
  // future one) gets the same 14-day clock with no risk of a call site
  // forgetting to set it. The retention cron purges rows past this deadline;
  // PATCH /intakes/:id/extend pushes it out by 7 more days.
  expiresAt DateTime @default(dbgenerated("(timezone('UTC'::text, now()) + '14 days'::interval)"))

  @@index([status])
  @@index([createdAt])
  @@index([expiresAt])
}

model CallReport {
  id                            Int      @id @default(autoincrement())
  callDuration                  Int
  callerType                    String
  callPurpose                   String
  summaryNotes                  String
  callerName                    String
  phone                         String
  email                         String?
  region                        String
  gender                        String
  sector                        String
  // "האם קיבל ליווי במרכז סיוע אחר?" — renamed from contactedOtherCenterBefore,
  // which asked about prior contact rather than support actually received.
  receivedSupportAtOtherCenter  Boolean
  isFamilyMemberOrAcquaintance  Boolean
  // 'first_time' | 'past' | 'dont_remember' — validated at the API layer, same
  // convention as region/gender/sector: a Prisma String, not a Prisma enum.
  magenContactHistory           String
  reportingDuty                 Boolean?
  createdAt                     DateTime @default(now())

  createdById Int?
  createdBy   User? @relation(fields: [createdById], references: [id])

  intake Intake?

  @@index([createdById])
  @@index([createdAt])
}
