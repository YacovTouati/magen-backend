generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

// ⚠️ PRODUCTION CUTOVER NOTE (SQLite -> Postgres):
// Prisma requires `provider` to be a static literal — it cannot be driven by an
// env var, and SQLite/Postgres are different SQL dialects, so this schema (and
// every file in prisma/migrations/) can only target ONE provider at a time.
// There is no safe way to make this toggle at runtime.
//
// When ready to cut over:
//   1. Stand up a local Postgres for dev (docker compose is simplest) so
//      dev/prod stay on the same dialect — do NOT try to keep SQLite for
//      local dev after this point, migrations will silently diverge.
//   2. Change `provider` below to "postgresql".
//   3. Swap the adapter in src/db/prisma.ts: `@prisma/adapter-better-sqlite3`
//      -> `@prisma/adapter-pg` (or drop the adapter entirely and use the
//      default PrismaClient, which speaks Postgres natively).
//   4. Archive prisma/migrations/* (it's SQLite-dialect SQL, inapplicable to
//      Postgres) and run `prisma migrate dev --name init` fresh against the
//      empty Postgres database to generate a new baseline migration.
//   5. Update DATABASE_URL — see .env for the production connection string
//      parameters (sslmode, connection_limit, pool_timeout, pgbouncer).
datasource db {
  provider = "sqlite"
}

enum UserRole {
  ADMIN
  VOLUNTEER
}

model User {
  id               Int               @id @default(autoincrement())
  email            String            @unique
  password         String
  name             String
  role             UserRole          @default(VOLUNTEER)
  reports          CallReport[]
  assignedIntakes  Intake[]
  shiftAssignments ShiftAssignment[]
  createdAt        DateTime          @default(now())
}

model ShiftAssignment {
  id          Int      @id @default(autoincrement())
  date        DateTime @unique

  volunteerId Int
  volunteer   User     @relation(fields: [volunteerId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([volunteerId])
}

enum IntakeUrgency {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum IntakeStatus {
  NEW
  NO_ANSWER
  ACTIVE
  CLOSED
  LONG_TERM
}

model Intake {
  id                   Int           @id @default(autoincrement())
  callerName           String
  phone                String
  contactedOtherCenter String
  caseDescription      String
  urgency              IntakeUrgency
  status               IntakeStatus  @default(NEW)

  assignedToId         Int?
  assignedTo           User?         @relation(fields: [assignedToId], references: [id])

  callReportId         Int?          @unique
  callReport           CallReport?   @relation(fields: [callReportId], references: [id])

  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@index([assignedToId])
  @@index([status])
  @@index([createdAt])
}

model CallReport {
  id                         Int       @id @default(autoincrement())
  callDuration               Int
  callerType                 String
  callPurpose                String
  summaryNotes               String
  callerName                 String
  phone                      String
  email                      String?
  region                     String
  gender                     String
  sector                     String
  contactedOtherCenterBefore Boolean
  reportingDuty              Boolean?
  createdAt                  DateTime  @default(now())

  createdById                Int?
  createdBy                  User?     @relation(fields: [createdById], references: [id])

  intake                     Intake?

  @@index([createdById])
  @@index([createdAt])
}
