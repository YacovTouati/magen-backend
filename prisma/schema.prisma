generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

// Cut over to Postgres (from the SQLite used during early local development).
// Local dev now requires a real Postgres instance — see .env for connection
// string parameters (sslmode, connection_limit, pool_timeout, pgbouncer).
// Note: Prisma 7 no longer allows `url` here — the connection string is supplied
// via prisma.config.ts (for the CLI) and via the adapter in src/db/prisma.ts
// (for the runtime client).
datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  VOLUNTEER
}

model User {
  id               Int               @id @default(autoincrement())
  email            String            @unique
  password         String
  name             String
  role             UserRole          @default(VOLUNTEER)
  reports          CallReport[]
  assignedIntakes  Intake[]
  shiftAssignments ShiftAssignment[]
  shifts           Shift[]
  createdAt        DateTime          @default(now())
}

model ShiftAssignment {
  id   Int      @id @default(autoincrement())
  date DateTime @unique

  volunteerId Int
  volunteer   User @relation(fields: [volunteerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([volunteerId])
}

// --- Volunteer self-service shift booking (coexists with ShiftAssignment,
// which stays as-is for admin pre-assignment / blocking out days) ---

enum ScheduleStatus {
  DRAFT
  OPEN
}

enum ShiftType {
  MORNING
  EVENING
}

enum ShiftStatus {
  OPEN
  LOCKED
}

model Schedule {
  id     Int            @id @default(autoincrement())
  // Natural 1-12, not JS Date's 0-indexed convention — this is a DB value future
  // integrations/reports will read directly; the API layer translates at the
  // boundary so the existing 0-indexed frontend calendar doesn't need to change.
  month  Int
  year   Int
  status ScheduleStatus @default(DRAFT)
  shifts Shift[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([month, year])
}

model Shift {
  id     Int         @id @default(autoincrement())
  date   DateTime
  type   ShiftType
  status ShiftStatus @default(OPEN)

  scheduleId Int
  schedule   Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  // SetNull (not Cascade, unlike ShiftAssignment): a locked shift is a historical
  // record of who worked it. Deleting the volunteer should clear the assignment,
  // not erase that the shift happened.
  volunteerId Int?
  volunteer   User? @relation(fields: [volunteerId], references: [id], onDelete: SetNull)

  // Set when a claim succeeds; also cleared/reset by an admin release. Cheap
  // audit trail, useful the moment anyone asks "when was this actually claimed."
  lockedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date, type])
  @@index([scheduleId])
  @@index([status])
  @@index([volunteerId])
}

enum IntakeUrgency {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum IntakeStatus {
  NEW
  NO_ANSWER
  ACTIVE
  CLOSED
  LONG_TERM
}

model Intake {
  id                   Int           @id @default(autoincrement())
  callerName           String
  phone                String
  contactedOtherCenter String
  caseDescription      String
  urgency              IntakeUrgency
  status               IntakeStatus  @default(NEW)

  assignedToId Int?
  assignedTo   User? @relation(fields: [assignedToId], references: [id])

  callReportId Int?        @unique
  callReport   CallReport? @relation(fields: [callReportId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assignedToId])
  @@index([status])
  @@index([createdAt])
}

model CallReport {
  id                         Int      @id @default(autoincrement())
  callDuration               Int
  callerType                 String
  callPurpose                String
  summaryNotes               String
  callerName                 String
  phone                      String
  email                      String?
  region                     String
  gender                     String
  sector                     String
  contactedOtherCenterBefore Boolean
  reportingDuty              Boolean?
  createdAt                  DateTime @default(now())

  createdById Int?
  createdBy   User? @relation(fields: [createdById], references: [id])

  intake Intake?

  @@index([createdById])
  @@index([createdAt])
}
